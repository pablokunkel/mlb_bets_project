# ── Secrets ──
.env
.env.*
!.env.example

# ── DB (lives one level up at <project_parent>/data/) ──
# The ../data/ entries below are noise (git doesn't honor .. in .gitignore
# patterns) but kept as documentation. The real protection is that the DB
# directory is outside the repo root and therefore not eligible for git.
# ../data/hr_bets.db
# ../data/cache/

# ── Local data dir (root only) — exclude IF a sibling 'data/' ever shows
#    up alongside the project (e.g., a temp scratch). LEADING SLASH IS
#    CRITICAL: matches root-level 'data/' only, NOT mlb_hr_bet_site/data/. ──
/data/

# ── Python ──
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/

# ── OS / editors ──
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# ── OneDrive / Netlify sync artifacts ──
.netlify/
desktop.ini

# ── Build / deploy ──
node_modules/
dist/
build/

# ── Logs ──
logs/
*.log

# ── Cache directories anywhere ──
**/cache/
**/.cache/

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
